# Contact form email (Resend). Copy to .env.local and fill in.
# If RESEND_API_KEY is unset, the contact form returns a friendly
# "email not yet configured" message instead of failing.

RESEND_API_KEY=
# Where enquiries are delivered (defaults to info@efmdevelopment.com):
CONTACT_TO_EMAIL=info@efmdevelopment.com
# Verified Resend sender (defaults to Resend's shared onboarding sender):
CONTACT_FROM_EMAIL="EFM Website <onboarding@resend.dev>"
